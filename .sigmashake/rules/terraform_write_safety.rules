# terraform_write_safety.rules
# Technology: terraform | Capability: write

rule terraform-hardcoded-aws-keys {
  enabled true
  priority 100
  severity error
  DENY write
  IF path GLOB "**/*.tf" AND content LINE_REGEX "access_key\\s*=\\s*[\"']AKIA.*[\"']"
  OR path GLOB "**/*.tf" AND content LINE_REGEX "secret_key\\s*=\\s*[\"'].*[\"']" AND content NOT CONTAINS "var."
  MESSAGE "Hardcoding AWS access keys or secret keys in Terraform files is a critical security risk. Use environment variables (AWS_ACCESS_KEY_ID), a credentials file, or an IAM role instead."
}

rule terraform-unpinned-module-source {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*.tf" AND content LINE_REGEX "source\\s*=\\s*[\"']github\\.com/.*[\"']" AND content NOT CONTAINS "?ref="
  MESSAGE "Using a GitHub module source without pinning to a specific commit or tag (?ref=) can break your infrastructure if the module's main branch introduces breaking changes or is compromised."
}

rule terraform-missing-backend {
  enabled true
  priority 75
  severity warning
  LOG write
  IF path GLOB "**/main.tf" AND content NOT CONTAINS "backend" AND content NOT CONTAINS "cloud {"
  MESSAGE "Storing terraform.tfstate locally can lead to sensitive data exposure and state corruption in team environments. Ensure you are using a secure remote backend (e.g., S3, Azure Blob, Terraform Cloud) for production infrastructure."
}
