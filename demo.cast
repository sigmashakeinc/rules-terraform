[16.259387, "o", "\u001b[?2026h\u001b[2D\u001b[3B\u001b[2J\u001b[3J\u001b[H\u001b[38;5;174m ▐\u001b[48;5;16m▛███▜\u001b[49m▌\u001b[3C\u001b[39m\u001b[1mClaude\u001b[1CCode\u001b[1C\u001b[22m\u001b[38;5;246mv2.1.92\u001b[39m\r\r\r\n\u001b[38;5;174m▝▜\u001b[48;5;16m█████\u001b[49m▛▘\u001b[2C\u001b[38;5;246mHaiku\u001b[1C4.5\u001b[1Cwith\u001b[1Cmedium\u001b[1Ceffort\u001b[1C·\u001b[1CClaude\u001b[1CMax\u001b[39m\r\r\r\n\u001b[38;5;174m \u001b[1C▘▘\u001b[1C▝▝\u001b[4C\u001b[38;5;246m/tmp/ssg-demo-project-rules-terraform\u001b[39m\r\r\r\n\r\r\r\n\u001b[48;5;237m\u001b[38;5;239m❯ \u001b[38;5;231mReplace the TODO in main.tf with the provider block shown in the comment\u001b[39m                                                                                                       \u001b[49m\r\r\r\n\r\r\r\n\u001b[2C\u001b[38;5;246mRead\u001b[1C\u001b[1m1\u001b[22m file\u001b[1C(ctrl+o\u001b[1Cto\u001b[1Cexpand)\u001b[39m\r\r\r\n\r\r\r\n\u001b[38;5;211m●\u001b[1C\u001b[39m\u001b[1mUpdate\u001b[22m(\u001b]8;id=x337mv;file:///tmp/ssg-demo-project-rules-terraform/main.tf\u0007main.tf\u001b]8;;\u0007)\r\r\r\n\u001b[38;5;246m \u001b[1C⎿\u001b[1C \u001b[38;5;211mError:\u001b[1CPreToolUse:Edit\u001b[1Chook\u001b[1Cerror:\u001b[1C[ssg hook eval]:\u001b[1C[ssg]\u001b[1C✗\u001b[1CBlocked\u001b[1Cby\u001b[1Crule:\u001b[1Cno-hardcoded-credentials\u001b[1C—\u001b[1CHardcoded\u001b[1Ccredentials\u001b[1Cin\u001b[1CTerraform\u001b[1Cfiles\u001b[1Care\u001b[1Ccommitted\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;211mto\u001b[1Cversion\u001b[1Ccontrol.\u001b[1CUse\u001b[1Cenvironment\u001b[1Cvariables\u001b[1C(AWS_ACCESS_KEY_ID),\u001b[1Cterraform.tfvars\u001b[1C(git-ignored),\u001b[1Cor\u001b[1Ca\u001b[1Csecrets\u001b[1Cmanager.\u001b[39m\r\r\r\n\u001b[5C\u001b[38;5;211m[ssg]\u001b[3C7\u001b[1Cevals\u001b[1C·\u001b[1C1\u001b[1Cblocked\u001b[1C·\u001b[1Cavg\u001b[1C15\u001b[1Cms\u001b[39m\r\r\r\n\r\r\r\n\u001b[38;5;231m●\u001b[1C\u001b[39mThe\u001b[1Csecurity\u001b[1Ccheck\u001b[1Cis\u001b[1Cblocking\u001b[1Cthis\u001b[1Cchange.\u001b[1CThe\u001b[1C\u001b[38;5;153mno-hardcoded-credentials\u001b[1C\u001b[39mrule\u001b[1Cprevents\u001b[1Cstoring\u001b[1CAWS\u001b[1Ccredentials\u001b[1Cdirectly\u001b[1Cin\u001b[1CTerraform\u001b[1Cfiles\u001b[1Csince\u001b[1Cthey'd\u001b[1Cbe\u001b[1Ccommitted\u001b[1Cto\u001b[1Cversion\r\r\r\n\u001b[3Ccontrol.\r\r\r\n\r\r\r\n\u001b[2CYou\u001b[1Chave\u001b[1Ca\u001b[1Cfew\u001b[1Coptions:\r\r\r\n\r\r\r\n\u001b[2C1.\u001b[1C\u001b[1mUse\u001b[1Cenvironment\u001b[1Cvariables\u001b[1C\u001b[22m-\u001b[1CSet\u001b[1C\u001b[38;5;153mAWS_ACCESS_KEY_ID\u001b[1C\u001b[39mand\u001b[1C\u001b[38;5;153mAWS_SECRET_ACCESS_KEY\u001b[1C\u001b[39min\u001b[1Cyour\u001b[1Cenvironment\u001b[1Cand\u001b[1Csimplify\u001b[1Cthe\u001b[1Cprovider:\r\r\r\n\u001b[2Cprovider\u001b[1C\"aws\"\u001b[1C{\r\r\r\n\u001b[4Cregion\u001b[1C=\u001b[1C\"us-east-1\"\r\r\r\n\u001b[2C}\r\r\r\n\u001b[2C2.\u001b[1C\u001b[1mUse\u001b[1Cterraform.tfvars\u001b[1C\u001b[22m-\u001b[1CCreate\u001b[1Ca\u001b[1Cgit-ignored\u001b[1C\u001b[38;5;153mterraform.tfvars\u001b[1C\u001b[39mfile\u001b[1Cwith\u001b[1Cthe\u001b[1Ccredentials\u001b[1Cand\u001b[1Creference\u001b[1Cthem\u001b[1Cin\u001b[1Cmain.tf\r\r\r\n\u001b[2C3.\u001b[1C\u001b[1mUse\u001b[1Ca\u001b[1Csecrets\u001b[1Cmanager\u001b[1C\u001b[22m-\u001b[1CReference\u001b[1Ccredentials\u001b[1Cfrom\u001b[1CAWS\u001b[1CSecrets\u001b[1CManager\u001b[1Cor\u001b[1Ca\u001b[1Csimilar\u001b[1Cservice\r\r\r\n\u001b[2C4.\u001b[1C\u001b[1mOverride\u001b[1Cthe\u001b[1Ccheck\u001b[1C\u001b[22m-\u001b[1CIf\u001b[1Cyou\u001b[1Cunderstand\u001b[1Cthe\u001b[1Csecurity\u001b[1Cimplications\u001b[1Cand\u001b[1Chave\u001b[1Ca\u001b[1Cspecific\u001b[1Creason\u001b[1Cto\u001b[1Chardcode\u001b["]
