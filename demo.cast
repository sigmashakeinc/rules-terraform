[15.825842, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A2.\u001b[1C\u001b[1mUse terraform.tfvars\u001b[1C\u001b[22m-\u001b[1CCreate\u001b[1Ca\u001b[1Cgit-ignored\u001b[1C\u001b[38;5;153mterraform.tfvars\u001b[1C\u001b[39mfile\u001b[1Cwith\u001b[1Cthe\u001b[1Ccredentials\u001b[1Cand\u001b[1Creference\u001b[1Cthem\u001b[1Cin\u001b[1Cmain.tf\r\u001b[1B  3. \u001b[1mUse a secrets manager\u001b[22m - Reference credentials from AWS Secrets Manager or a similar service                                                                                 \r\u001b[1B   \r\u001b[2B\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m                                                         \r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
[16.218693, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A4.\u001b[1C\u001b[1mOverride the check\u001b[1C\u001b[22m-\u001b[1CIf\u001b[1Cyou\u001b[1Cunderstand\u001b[1Cthe\u001b[1Csecurity\u001b[1Cimplications\u001b[1Cand\u001b[1Chave\u001b[1Ca\u001b[1Cspecific\u001b[1Creason\u001b[1Cto\u001b[1Chardcode\u001b[1Cthem,\u001b[1Cyou\u001b[1Ccan\u001b[1Cdisable\u001b[1Cthis\u001b[1Crule\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B  Which\u001b[1Capproach\u001b[1Cwould\u001b[1Cyou\u001b[1Cprefer?\r\u001b[1B                                                                                                                                                                                 \r\u001b[1B\u001b[38;5;174m✻\u001b[1COrchestrating… \u001b[39m                                           \r\r\r\n\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[38;5;246m❯ \u001b[39m\u001b[7m \u001b[27m\r\r\r\n\u001b[38;5;244m─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────\u001b[39m\r\r\r\n\u001b[2C\u001b[38;5;147m⏵⏵\u001b[1Caccept\u001b[1Cedits\u001b[1Con\u001b[38;5;246m (shift+tab\u001b[1Cto\u001b[1Ccycle)\u001b[1C·\u001b[1Cesc\u001b[1Cto\u001b[1Cinterrupt\u001b[39m\r\r\r\n\u001b[2C\u001b[3A\u001b[?2026l"]
